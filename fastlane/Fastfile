default_platform(:ios)

WORKSPACE = "ios/Runner.xcworkspace"
SCHEME    = "Runner"

platform :ios do
  private_lane :api_key do
    app_store_connect_api_key(
      key_id:       ENV["API_KEY_ID"],
      issuer_id:    ENV["API_KEY_ISSUER_ID"],
      key_filepath: File.expand_path("../fastlane/AuthKey_Y6R928987W.p8", __dir__),
    )
  end

  # ── Screenshots (Xcode UI tests via Snapfile) ──────────────────────────────
  desc "Gera screenshots em todos os idiomas e dispositivos configurados no Snapfile"
  lane :screenshots do
    capture_ios_screenshots(
      workspace: WORKSPACE,
      scheme: SCHEME,
      derived_data_path: "build/DerivedData",
      output_directory: "fastlane/screenshots",
      clear_previous_screenshots: true,
      override_status_bar: true,
      localize_simulator: true
    )
  end

  # ── Screenshots (Flutter widget tests — plain + mockup) ───────────────────
  desc "Gera todos os screenshots via Flutter widget tests"
  lane :flutter_screenshots do
    sh("cd .. && flutter test test/screenshots_test.dart 2>&1")
  end

  # ── Screenshots mockup only ────────────────────────────────────────────────
  desc "Gera apenas os screenshots com mockup (bg + título + frame)"
  lane :flutter_mockup_screenshots do
    sh("cd .. && flutter test test/screenshots_test.dart --name mockup 2>&1")
  end

  # ── Metadata ───────────────────────────────────────────────────────────────
  desc "Envia apenas os textos da loja (sem screenshots, sem binário)"
  lane :upload_metadata do
    deliver(
      api_key:             api_key,
      skip_screenshots:    true,
      skip_binary_upload:  true,
      force:               true,
      run_precheck_before_submit: false
    )
  end

  # ── Screenshots plain → App Store Connect ─────────────────────────────────
  desc "Envia screenshots plain (sem frame) para o App Store Connect"
  lane :upload_screenshots do
    deliver(
      api_key:               api_key,
      screenshots_path:      "fastlane/screenshots/plain",
      skip_metadata:         true,
      skip_binary_upload:    true,
      overwrite_screenshots: true,
      force:                 true,
      run_precheck_before_submit: false
    )
  end

  # ── Gera mockup + sobe para App Store Connect ──────────────────────────────
  desc "Gera screenshots com mockup e sobe para o App Store Connect"
  lane :take_screenshot_upload do
    flutter_mockup_screenshots
    deliver(
      api_key:               api_key,
      screenshots_path:      "fastlane/screenshots/mockup",
      skip_metadata:         true,
      skip_binary_upload:    true,
      overwrite_screenshots: true,
      force:                 true,
      run_precheck_before_submit: false
    )
  end

  # ── Tudo de uma vez ────────────────────────────────────────────────────────
  desc "Gera screenshots via Flutter tests e sobe metadata + screenshots para o App Store Connect"
  lane :release_metadata do
    flutter_screenshots
    deliver(
      api_key:               api_key,
      screenshots_path:      "fastlane/screenshots/plain",
      skip_binary_upload:    true,
      overwrite_screenshots: true,
      force:                 true,
      run_precheck_before_submit: false
    )
  end
end
